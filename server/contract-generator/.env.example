# Example local-development environment for ds-contract-generator.
#
# Usage:
#   cp .env.example .env
#   poetry run uvicorn app.main:app --reload --port 8082
#
# Pydantic Settings reads `.env` from the current working directory at
# startup, so values here become DS__* env vars without an export step.
#
# IN PRODUCTION DO NOT USE A .env FILE — the Helm chart sets these env
# vars on the Deployment spec. See deploy/values/hus-generator.yaml.

# --- Node identity (set per deployment) ----------------------------------
DS__NODE_ID=localhost

# --- Signing key (local dev: file on disk; production: K8s Secret) -------
DS__SIGNING_KEY_PATH=./local-ed25519.pem
DS__SIGNING_KEY_ID=localhost#key-1

# --- Upstream services ---------------------------------------------------
# In dev with environment=development AND clearing_house_url=localhost,
# the Generator falls back to an in-memory stub Clearing House. Useful
# for offline testing.
DS__CLEARING_HOUSE_URL=http://localhost:9001

# --- Token defaults ------------------------------------------------------
DS__DEFAULT_TTL_SECONDS=3600
DS__MAX_ITEMS_PER_CONTRACT=50

# --- Catalog field schema (config-driven) --------------------------------
# Path to the YAML that defines which catalog item attributes go into the
# token. Defaults to the file shipped in app/core/catalog_fields.yaml.
# DS__CATALOG_FIELDS_CONFIG_PATH=./app/core/catalog_fields.yaml

# --- Server --------------------------------------------------------------
DS__PORT=8082
DS__HOST=0.0.0.0
DS__LOG_LEVEL=INFO
DS__ENVIRONMENT=development
