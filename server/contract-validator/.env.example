# Example local-development environment for ds-contract-validator.
#
# Usage:
#   cp .env.example .env
#   poetry run uvicorn app.main:app --reload --port 8083
#
# Pydantic Settings reads `.env` automatically.
#
# IN PRODUCTION DO NOT USE A .env FILE — the Helm chart sets these env
# vars on the Deployment spec. See deploy/values/hus-validator.yaml.

# --- Node identity -------------------------------------------------------
DS__NODE_ID=localhost

# --- Upstream services ---------------------------------------------------
DS__CLEARING_HOUSE_URL=http://localhost:9001

# When set, Validator hits {template}/.well-known/jwks.json regardless of iss.
# Leave empty for cross-node scenarios — Validator then derives the URL
# from the token's iss claim.
DS__JWKS_BASE_URL_TEMPLATE=http://localhost:8082

# --- Behaviour -----------------------------------------------------------
DS__LEEWAY_SECONDS=5
DS__JWKS_CACHE_TTL_SECONDS=3600
DS__HTTP_TIMEOUT_SECONDS=5.0

# --- Server --------------------------------------------------------------
DS__PORT=8083
DS__HOST=0.0.0.0
DS__LOG_LEVEL=INFO
DS__ENVIRONMENT=development
